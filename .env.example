DOWNLOAD_DIR=fastq
MANIFEST=config/fastqs.template.tsv

SAREK_VERSION=3.9.0
PROFILE=apptainer
SLURM_CONFIG=config/slurm.example.config
NXF_OPTS='-Xms1g -Xmx4g'

DOWNLOAD_CACHE=true
OUTDIR_CACHE=/path/to/cache
VEP_CACHE=/path/to/cache/vep_cache
SNPEFF_CACHE=/path/to/cache/snpeff_cache

# Optional, only if you need a cluster-specific reference location:
# IGENOMES_BASE=/path/to/igenomes
